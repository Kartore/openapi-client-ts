{
  "name": "@kartore/openapi-client-ts-generator",
  "version": "0.0.10",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "http://github.com/Kartore/openapi-client-ts/tree/main/packages/generator#readme",
  "bugs": {
    "url": "https://github.com/kartore/openapi-client-ts/issues"
  },
  "license": "MIT",
  "author": "Akane Kamiseto <akane@nekoyasan.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kartore/openapi-client-ts"
  },
  "bin": {
    "openapi-gen": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./node": "./dist/node.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@scalar/json-magic": "^0.12.4",
    "@scalar/openapi-parser": "^0.25.6",
    "@scalar/openapi-types": "0.6.1"
  },
  "devDependencies": {
    "@tanstack/react-query": "catalog:",
    "@tanstack/svelte-query": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "bumpp": "^11.0.1",
    "vite-plus": "catalog:"
  }
}
