{
  "name": "@kartore/openapi-client-ts-generator",
  "version": "0.0.1",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/kartore/openapi-client-ts/packages/generator#readme",
  "bugs": {
    "url": "https://github.com/kartore/openapi-client-ts/issues"
  },
  "license": "MIT",
  "author": "Akane Kamiseto <akane@nekoyasan.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kartore/openapi-client-ts.git"
  },
  "bin": {
    "openapi-gen": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@scalar/json-magic": "^0.12.4",
    "@scalar/openapi-parser": "^0.25.6"
  },
  "devDependencies": {
    "@scalar/openapi-types": "^0.6.1",
    "@tanstack/react-query": "catalog:",
    "@tanstack/svelte-query": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "bumpp": "^11.0.1",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.13"
  }
}
